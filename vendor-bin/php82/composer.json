{
    "require-dev": {
        "php": ">=8.2",
        "ergebnis/composer-normalize": "^2.50",
        "guanguans/monorepo-builder-worker": "^3.1",
        "illuminate/support": "^12.55 || ^13.0",
        "peckphp/peck": "^0.2"
    },
    "suggest": {
        "canvural/larastan-strict-rules": "php > 8.1",
        "larastan/larastan": "php > 8.1",
        "mrpunyapal/peststan": "php > 8.1",
        "mrpunyapal/rector-pest": "php > 8.1",
        "php-standard-library/php-standard-library": "php > 8.1",
        "php-standard-library/phpstan-extension": "php > 8.1",
        "rector/mockstan": "php > 8.1",
        "roave/backward-compatibility-check": "php > 8.1",
        "roave/no-floaters": "php > 8.1",
        "symplify/coding-standard": "php > 8.1",
        "symplify/easy-coding-standard": "php > 8.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "theofidry/composer-inheritance-plugin": false,
            "wikimedia/composer-merge-plugin": false
        },
        "sort-packages": true
    }
}
